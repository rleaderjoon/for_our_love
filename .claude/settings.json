{
  "permissions": {
    "allow": [
      "Bash(git fetch *)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(pwsh *)",
      "Bash(powershell *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -File .claude\\hooks\\aws-check.ps1"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"\n=== 세션 종료 체크리스트 ===\n[ ] git commit (변경사항 있으면)\n[ ] 문서 업데이트 필요 여부 확인\n[ ] memory/ 업데이트 필요 여부 확인\""
          }
        ]
      }
    ]
  }
}
