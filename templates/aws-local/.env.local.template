# .env.local — 로컬 테스트용 환경변수
# 이 파일을 .env.local 로 복사한 뒤 프로젝트에 맞게 수정하세요
# .gitignore에 .env.local 추가 필수
#
# 사용법: 앱 실행 시 .env 대신 .env.local 로드
#   Python: python-dotenv → dotenv_values('.env.local')
#   Node:   NODE_ENV=local && dotenv -e .env.local -- node app.js

# ── 데이터베이스 (RDS → localhost:5432) ─────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=app
DB_USER=postgres
DB_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app

# ── Redis (ElastiCache → localhost:6379) ─────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ── AWS SDK → LocalStack (localhost:4566) ───────────────────────
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=ap-northeast-2

# S3 버킷 이름은 LocalStack에서도 동일하게 생성해야 합니다
# aws --endpoint-url=http://localhost:4566 s3 mb s3://my-bucket

# ── 기타 서비스 엔드포인트 ───────────────────────────────────────
# EC2_HOST=localhost
# API_URL=http://localhost:8000
