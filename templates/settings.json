{
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(git fetch *)",
      "Bash(rtk git *)",
      "Bash(rtk npm *)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"\n=== 세션 종료 체크리스트 ===\n[ ] git commit (변경사항 있으면)\n[ ] 문서 업데이트 필요 여부 확인\n[ ] memory/ 업데이트 필요 여부 확인\""
          }
        ]
      }
    ]
  }
}
